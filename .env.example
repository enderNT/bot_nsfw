# =========================
# Core app
# =========================
APP_ENV=development
APP_NAME=stateful-assistant
APP_HOST=0.0.0.0
APP_PORT=3000
APP_LOG_LEVEL=INFO
APP_LOG_TO_CONSOLE=true
APP_LOG_TO_FILE=true
APP_LOG_DIR=./var/log/stateful-assistant
APP_LOG_FILE=app.log
# Optional overrides. If omitted:
# - development => 3 files / 200 lines each
# - production => 10 files / 500 lines each
# APP_LOG_MAX_FILES=
# APP_LOG_MAX_LINES=
APP_INSTANCE_ID=
APP_CONTAINER_NAME=
APP_CONTAINER_ID=
APP_HOST_NAME=
APP_DEFAULT_LOCALE=es-MX
APP_DEFAULT_TIMEZONE=America/Mexico_City

# =========================
# Bun runtime
# =========================
BUN_ENV=development
BUN_RUNTIME=bun

# =========================
# LLM
# =========================
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-5-mini
LLM_TIMEOUT_MS=30000
LLM_TEMPERATURE=

# =========================
# Routing / prompt budget
# =========================
ROUTER_CONFIDENCE_THRESHOLD=0.62
ROUTER_KNOWLEDGE_THRESHOLD=0.58
PROMPT_MEMORY_MAX_ITEMS=3
PROMPT_MEMORY_BUDGET_CHARS=1200
PROMPT_RECENT_TURNS_LIMIT=3
PROMPT_SUMMARIZE_ON_OVERFLOW=true

# =========================
# Short-term state
# =========================
STATE_SUMMARY_REFRESH_TURN_THRESHOLD=4
STATE_SUMMARY_REFRESH_CHAR_THRESHOLD=900

# =========================
# Long-term memory component
# =========================
MEMORY_PROVIDER=in_memory
MEMORY_ENABLED=true
MEMORY_AGENT_ID=default-assistant
MEMORY_TOP_K=5
MEMORY_SCORE_THRESHOLD=0.0
MEMORY_INFER=true
MEMORY_CUSTOM_INSTRUCTIONS_VERSION=v1
MEM0_API_KEY=
MEM0_BASE_URL=http://127.0.0.1:8000
MEM0_ORG_ID=
MEM0_PROJECT_ID=

# =========================
# Retrieval / knowledge
# =========================
KNOWLEDGE_PROVIDER=none
KNOWLEDGE_ENABLED=false
KNOWLEDGE_TOP_K=5
KNOWLEDGE_TIMEOUT_MS=10000

# =========================
# Channel adapter
# =========================
CHANNEL_PROVIDER=none
CHANNEL_REPLY_ENABLED=false
CHATWOOT_BASE_URL=
CHATWOOT_API_ACCESS_TOKEN=

# =========================
# Tracing / observability
# =========================
TRACE_BACKEND=in_memory
TRACE_APP_KEY=stateful-assistant
TRACE_BATCH_SIZE=25
TRACE_FLUSH_INTERVAL_MS=1000
TRACE_PROJECTORS_ENABLED=true
TRACE_STORE_RAW_RECALL=true
TRACE_STORE_PROMPT_DIGEST=true

# =========================
# DSPy bridge
# =========================
DSPY_ENABLED=false
DSPY_SERVICE_URL=http://dspy-service:8001
DSPY_TIMEOUT_MS=4000
DSPY_RETRY_COUNT=1
DSPY_ROUTE_DECISION_ENABLED=false
DSPY_CONVERSATION_REPLY_ENABLED=false
DSPY_KNOWLEDGE_REPLY_ENABLED=false
DSPY_ACTION_REPLY_ENABLED=false
DSPY_MODEL=
DSPY_API_KEY=
DSPY_API_BASE=
DSPY_TEMPERATURE=0.2
DSPY_MAX_TOKENS=900
DSPY_OPTIMIZED_DIR=./dspy_service/optimized

# =========================
# Docker / container runtime
# =========================
DOCKER_APP_PORT=3000
DOCKER_DSPY_PORT=8001

# =========================
# Optional component: channel adapter
# =========================
CHANNEL_API_BASE_URL=
CHANNEL_API_TOKEN=

# =========================
# Optional component: retrieval adapter
# =========================
RETRIEVAL_BASE_URL=
RETRIEVAL_API_KEY=
RETRIEVAL_COLLECTION_NAME=assistant_knowledge
RETRIEVAL_VECTOR_SIZE=1536
RETRIEVAL_SIMULATE=true

# =========================
# Optional component: external trace sink
# =========================
TRACE_EXTERNAL_DSN=
TRACE_EXTERNAL_SCHEMA=tracing
TRACE_EXTERNAL_SETUP_ON_START=true
